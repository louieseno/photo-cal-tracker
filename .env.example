# ─────────────────────────────────────────────────────────────────────────────
# Expo app env — PUBLIC values only.
#
# Anything prefixed with EXPO_PUBLIC_ is inlined into the app bundle, so it is
# NOT secret. NEVER put the Anthropic API key here — it lives only in the Edge
# Function (see supabase/.env.example). Copy this file to `.env` and fill in.
# ─────────────────────────────────────────────────────────────────────────────

# Your Supabase project URL, e.g. https://abcdefghijkl.supabase.co
# The app calls the function at: ${EXPO_PUBLIC_SUPABASE_URL}/functions/v1/analyze-meal
EXPO_PUBLIC_SUPABASE_URL=

# Supabase anon (publishable) key — public by design, safe to ship in the client.
# Project Settings → API → Project API keys → anon / public.
EXPO_PUBLIC_SUPABASE_ANON_KEY=
