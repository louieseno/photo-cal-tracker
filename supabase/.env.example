# ─────────────────────────────────────────────────────────────────────────────
# Edge Function secret — SERVER-SIDE ONLY. This must NEVER reach the app bundle.
#
# Local function dev reads this file:
#   supabase functions serve analyze-meal --env-file supabase/.env --no-verify-jwt
#
# Production (deployed function) uses Supabase secrets instead — do NOT rely on
# this file there:
#   supabase secrets set ANTHROPIC_API_KEY=sk-ant-...
#
# Copy this file to supabase/.env (gitignored) and fill in.
# ─────────────────────────────────────────────────────────────────────────────

ANTHROPIC_API_KEY=sk-ant-...
